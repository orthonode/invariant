# ═══════════════════════════════════════════════════════════════════════════════
# INVARIANT — .gitignore
# Deterministic Trust Infrastructure for Bittensor
# by Orthonode Infrastructure Labs · orthonode.xyz
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL DOCUMENTS — never publish planning/debug/execution internals
# ─────────────────────────────────────────────────────────────────────────────

# Word / Office planning docs
INVARIANT_*.docx
*.docx

# Internal debug and status reports
INVARIANT_DEBUG_REPORT.md
*_DEBUG_REPORT.md

# Local subtensor checkout — large Rust workspace, not part of this repo
subtensor/


# ─────────────────────────────────────────────────────────────────────────────
# CRITICAL SECURITY — NEVER COMMIT THESE
# ─────────────────────────────────────────────────────────────────────────────

# Seed phrases / mnemonics — ABSOLUTE NEVER
seed-phrase/
seed-phrase/**
**/seed-phrase/
**/seed-phrase/**
*.seed
*.mnemonic
mnemonic.txt
seed.txt

# Bittensor wallets (contain private keys)
.bittensor/
**/.bittensor/
wallets_*.json
wallet_*.json
hotkeys/
coldkeys/

# Environment secrets
.env
.env.local
.env.*.local
.env.production
*.secret
secrets.json
secrets.yaml
secrets.yml

# ─────────────────────────────────────────────────────────────────────────────
# INVARIANT RUNTIME DATA — DO NOT COMMIT
# ─────────────────────────────────────────────────────────────────────────────

# Miner and validator data directories
miner_data/
validator_data/
invariant_miner_data/
invariant_validator_data/
node_data/

# Gate state — counter state is security-sensitive
invariant_state.json
gate_state.json
*.state.json

# OAP ledgers — behavioral history (can be large, node-specific)
oap_ledgers.json
oap.json
*.oap.json

# Registry — validator-specific, not shared
invariant_registry.json
registry.json
*.registry.json

# Miner identity (contains agent_id bound to hotkey)
identity.json
miner_identity.json

# Counter state (security-sensitive for Gate 3)
counter.json
miner_counter.json

# Backup files
*.json.bak
*.json.backup
registry.json.bak
oap_ledgers.json.bak
gate_state.json.bak

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions (compiled Rust extension .so files)
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdid/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
.env/
pyenv/

# pip
pip-log.txt
pip-delete-this-directory.txt

